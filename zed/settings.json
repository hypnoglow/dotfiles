// Reference: https://zed.dev/docs/reference/all-settings
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // (

  // General

  "cli_default_open_behavior": "existing_window",
  "autosave": "on_focus_change",
  "use_system_path_prompts": true,
  "when_closing_with_no_tabs": "keep_window_open",

  "session": {
    "trust_all_worktrees": true,
  },

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  "feature_flags": {
    // https://github.com/zed-industries/zed/blob/main/crates/feature_flags/src/flags.rs
    "acp-beta": "off",
  },

  // Appearance

  "ui_font_size": 16,
  "buffer_font_size": 15,

  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte - No Italics",
    "dark": "Catppuccin Macchiato - No Italics",
  },

  "icon_theme": {
    "mode": "dark",
    "light": "Colored Zed Icons Theme Light",
    "dark": "Colored Zed Icons Theme Dark",
  },

  // Editor

  "auto_signature_help": true,
  "show_signature_help_after_edits": true,
  "show_wrap_guides": true,
  "wrap_guides": [80, 120],
  "excerpt_context_lines": 5,
  "expand_excerpt_lines": 10,
  "semantic_tokens": "combined", // https://zed.dev/docs/semantic-tokens

  // Git

  "diff_view_style": "split",

  "tabs": {
    "git_status": true,
  },

  "git_panel": {
    "dock": "right",
    "tree_view": true,
  },

  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },

  // AI

  "show_edit_predictions": true,
  "edit_predictions": {
    "provider": "zed",
    "disabled_globs": ["*.journal"],
  },

  "agent": {
    "play_sound_when_agent_done": "always",
    "notify_when_agent_waiting": "primary_screen",
    "profiles": {},
    "default_profile": "write",
    "default_model": {
      "enable_thinking": true,
      "provider": "ollama",
      "model": "qwen3.5:35b-a3b-coding-nvfp4",
    },
    "model_parameters": [],
  },

  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "pi-acp": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "effort": "high",
        "model": "opus",
      },
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
  },

  // Languages

  "languages": {
    "JavaScript": {
      "prettier": {
        "singleQuote": true,
      },
    },
    "TypeScript": {
      "prettier": {
        "singleQuote": true,
      },
    },
    "YAML": {
      "format_on_save": "on",
    },
  },

  // Other

  "terminal": {
    "env": {
      "EDITOR": "zed --wait",
      "VISUAL": "zed --wait",
    },
  },

  "auto_install_extensions": {
    "toml": true,
    "sql": true,
  },

  // )
}
