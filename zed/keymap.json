// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  // Subword navigation and deletion in editors.
  {
    "context": "Editor",
    "bindings": {
      "alt-left": "editor::MoveToPreviousSubwordStart",
      "alt-shift-left": "editor::SelectToPreviousSubwordStart",
      "alt-right": "editor::MoveToNextSubwordEnd",
      "alt-shift-right": "editor::SelectToNextSubwordEnd",
      "alt-delete": "editor::DeleteToNextSubwordEnd",
      "alt-backspace": "editor::DeleteToPreviousSubwordStart",
    },
  },
  // Tasks
  {
    "bindings": {
      "cmd-alt-p": ["task::Spawn", { "task_name": "Project Finder" }],
      "cmd-alt-shift-p": [
        "task::Spawn",
        { "task_name": "Project Finder (New Window)" },
      ],
      "ctrl-shift-l": [
        "task::Spawn",
        {
          "task_name": "Lazygit",
        },
      ],
    },
  },
  {
    // TODO: practice!
    "context": "Editor",
    "bindings": {
      "ctrl-shift-f12": "editor::GoToNextReference",
    },
  },
  {
    "bindings": {
      "ctrl-alt-cmd-n": "multi_workspace::NextProject",
    },
  },
  // Closing project / window.
  // Override default `workspace::CloseWindow` (cmd-shift-w) to close the
  // project instead; keep window-closing under a more deliberate chord.
  {
    "bindings": {
      "alt-w": ["action::Sequence", [["workspace::CloseProject", 0]]],
      "cmd-shift-w": "workspace::CloseProject",
      "ctrl-cmd-shift-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-}": "multi_workspace::NextProject",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-{": "multi_workspace::PreviousProject",
    },
  },
]
